---
import "../styles/global.css";

const {
  title = "Aamir Azad",
  description =
    "Rochester Institute of Technology Freshman who loves learning and building things."
} = Astro.props;

const siteUrl = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, siteUrl);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0b0b0b" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Aamir Azad" />
    <meta property="og:url" content={canonical.href} />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
